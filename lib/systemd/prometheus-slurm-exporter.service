[Unit]
Description=Prometheus SLURM Exporter
After=network.target

[Service]
# Built via: go build -o /usr/local/bin/prometheus-slurm-exporter ./cmd/exporter/
ExecStart=/usr/local/bin/prometheus-slurm-exporter
# Add --gpus-acct and/or --fairshare-acct as needed
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
